generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admin {
  id       Int     @id(map: "pk_admin") @default(autoincrement())
  email    String  @db.VarChar(50)
  telefono String? @db.VarChar(15)
  password String
}

model cancha {
  id              Int        @id(map: "pk_cancha") @default(autoincrement())
  precioBase      Float      @db.Real
  precioAdicional Float      @db.Real
  precioSe_a      Float      @map("precioSeña") @db.Real
  id_complejo     Int
  id_tipoCancha   Int
  complejo        complejo   @relation(fields: [id_complejo], references: [id], onDelete: Cascade, map: "fk_complejo")
  tipoCancha      tipoCancha @relation(fields: [id_tipoCancha], references: [id], onDelete: SetNull, map: "fk_tipoCancha")
  turno           turno[]
}

model cliente {
  id              Int      @id(map: "pk_cliente") @default(autoincrement())
  email           String   @db.VarChar(50)
  telefono        String?  @db.VarChar(15)
  password        String
  fechaNacimiento DateTime @db.Date
  nombre          String   @db.VarChar(50)
  apellido        String   @db.VarChar(50)
  turno           turno[]
}

model complejo {
  id              Int       @id(map: "pk_complejo") @default(autoincrement())
  direccion       String    @db.VarChar(50)
  nombre          String    @db.VarChar(30)
  horarioApertura DateTime  @db.Time(6)
  horarioCierre   DateTime  @db.Time(6)
  id_encargado    Int
  id_due_o        Int       @map("id_dueño")
  id_localidad    Int
  cancha          cancha[]
  due_o           due_o     @relation(fields: [id_due_o], references: [id], onDelete: SetNull, map: "fk_dueño")
  encargado       encargado @relation(fields: [id_encargado], references: [id], onDelete: SetNull, map: "fk_encargado")
  localidad       localidad @relation(fields: [id_localidad], references: [id], onDelete: SetNull, map: "fk_localidad")
}

model due_o {
  id          Int        @id(map: "pk_dueño") @default(autoincrement())
  email       String     @db.VarChar(50)
  telefono    String?    @db.VarChar(15)
  password    String
  cuit        String     @db.VarChar(15)
  razonSocial String     @db.VarChar(30)
  complejo    complejo[]

  @@map("dueño")
}

model encargado {
  id       Int        @id(map: "pk_encargado") @default(autoincrement())
  email    String     @db.VarChar(50)
  telefono String?    @db.VarChar(15)
  password String
  complejo complejo[]
}

model localidad {
  id           Int        @id(map: "pk_ciudad") @default(autoincrement())
  codigoPostal String     @db.VarChar
  id_provincia Int
  complejo     complejo[]
  provincia    provincia  @relation(fields: [id_provincia], references: [id], onDelete: Cascade, map: "fk_provincia")
}

model provincia {
  id        Int         @id(map: "pk_provincia") @default(autoincrement())
  nombre    String      @db.VarChar
  localidad localidad[]
}

model tipoCancha {
  id      Int      @id(map: "pk_tipoCancha") @default(autoincrement())
  deporte String   @db.VarChar(50)
  cancha  cancha[]
}

model tipoTurno {
  id          Int     @id(map: "pk_tipoTurno") @default(autoincrement())
  nombre      String  @db.VarChar(20)
  descripcion String  @db.VarChar(255)
  turno       turno[]
}

model turno {
  id            Int       @id(map: "pk_turno") @default(autoincrement())
  id_cliente    Int
  id_cancha     Int
  id_tipoTurno  Int
  horarioInicio DateTime  @db.Time(6)
  horarioFin    DateTime  @db.Time(6)
  cancha        cancha    @relation(fields: [id_cancha], references: [id], onDelete: SetDefault, map: "fk_cancha")
  cliente       cliente   @relation(fields: [id_cliente], references: [id], onDelete: SetDefault, map: "fk_cliente")
  tipoTurno     tipoTurno @relation(fields: [id_tipoTurno], references: [id], onDelete: SetDefault, map: "fk_tipoTurno")
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
model usuario {
  id       Int     @id(map: "pk_usuario") @default(autoincrement())
  email    String  @db.VarChar(50)
  telefono String? @db.VarChar(15)
  password String
}
