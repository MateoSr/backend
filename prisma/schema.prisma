generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model cancha {
  nro           Int        @default(autoincrement())
  id_complejo   Int
  id_tipoCancha Int
  complejo      complejo   @relation(fields: [id_complejo], references: [id], onDelete: Cascade, map: "fk_complejo")
  tipoCancha    tipoCancha @relation(fields: [id_tipoCancha], references: [id], onDelete: SetNull, map: "fk_tipoCancha")
  precio        precio[]
  turno         turno[]

  @@id([id_complejo, nro], map: "pk_cancha")
}

model complejo {
  id           Int       @id(map: "pk_complejo") @default(autoincrement())
  direccion    String    @db.VarChar(50)
  nombre       String    @db.VarChar(30)
  id_encargado Int
  id_due_o     Int       @map("id_dueño")
  id_localidad Int
  cancha       cancha[]
  due_o        usuario   @relation("ComplejosDelDueno", fields: [id_due_o], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dueño")
  encargado    usuario   @relation("ComplejosDelEncargado", fields: [id_encargado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_encargado")
  localidad    localidad @relation(fields: [id_localidad], references: [id], onDelete: SetNull, map: "fk_localidad")
  horario      horario[]
}

model localidad {
  id           Int        @id(map: "pk_ciudad") @default(autoincrement())
  codigoPostal String     @db.VarChar
  id_provincia Int
  complejo     complejo[]
  provincia    provincia  @relation(fields: [id_provincia], references: [id], onDelete: Cascade, map: "fk_provincia")
}

model provincia {
  id        Int         @id(map: "pk_provincia") @default(autoincrement())
  nombre    String      @db.VarChar
  localidad localidad[]
}

model tipoCancha {
  id      Int      @id(map: "pk_tipoCancha") @default(autoincrement())
  deporte String   @db.VarChar(50)
  cancha  cancha[]
}

model tipoTurno {
  id          Int     @id(map: "pk_tipoTurno") @default(autoincrement())
  nombre      String  @db.VarChar(20)
  descripcion String  @db.VarChar(255)
  turno       turno[]
}

model turno {
  id                Int       @id(map: "pk_turno") @default(autoincrement())
  id_cliente        Int
  id_tipoTurno      Int
  horarioInicio     DateTime  @db.Time(6)
  horarioFin        DateTime  @db.Time(6)
  id_complejo       Int
  nro_cancha        Int
  estado            String    @db.VarChar(15)
  motivoCancelacion String?   @db.VarChar(100)
  cancha            cancha    @relation(fields: [id_complejo, nro_cancha], references: [id_complejo, nro], onDelete: NoAction, onUpdate: NoAction, map: "fk_turno_cancha")
  cliente           usuario   @relation(fields: [id_cliente], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cliente")
  tipoTurno         tipoTurno @relation(fields: [id_tipoTurno], references: [id], onDelete: SetDefault, map: "fk_tipoTurno")
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
model usuario {
  id                Int         @id(map: "pk_usuario") @default(autoincrement())
  email             String      @db.VarChar(50)
  telefono          String?     @db.VarChar(15)
  password          String
  fechaNacimiento   DateTime?   @db.Date
  nombre            String?     @db.VarChar(50)
  apellido          String?     @db.VarChar(50)
  cuit              String?     @db.VarChar(15)
  razonSocial       String?     @db.VarChar(30)
  idTipoUsuario     Int
  complejoDueno     complejo[]  @relation("ComplejosDelDueno")
  complejoEncargado complejo[]  @relation("ComplejosDelEncargado")
  turno             turno[]
  tipoUsuario       tipoUsuario @relation(fields: [idTipoUsuario], references: [id], onDelete: NoAction, map: "fk_usuario_tipoUsuario")
}

model precio {
  id_complejo     Int
  nro_cancha      Int
  precioBase      Float    @db.Real
  precioAdicional Float    @db.Real
  precioSe_a      Float    @default(0) @map("precioSeña") @db.Real
  fechaDesde      DateTime @db.Date
  cancha          cancha   @relation(fields: [id_complejo, nro_cancha], references: [id_complejo, nro], onDelete: NoAction, onUpdate: NoAction, map: "fk_precio_cancha")

  @@id([id_complejo, nro_cancha, fechaDesde], map: "pk_precio")
}

model tipoUsuario {
  id          Int       @id(map: "pk_tipoUsuario") @default(autoincrement())
  descripcion String    @db.VarChar(20)
  usuario     usuario[]
}

model horario {
  id_complejo     Int
  num_dia         Int
  horarioApertura DateTime @db.Time(6)
  horarioCierre   DateTime @db.Time(6)
  complejo        complejo @relation(fields: [id_complejo], references: [id], onDelete: Cascade, map: "fk_horario_complejo")

  @@id([num_dia, id_complejo], map: "pk_horario")
}
